    dcterms:source <https://esplora.istat.it/> ;
    dcterms:title "Occupati ISTAT per provincia, media annua 2025"@it ;
    qb:structure idpt:dsd-occupati-istat ;
    sdmx-attribute:unitMeasure "migliaia di persone"@it .

