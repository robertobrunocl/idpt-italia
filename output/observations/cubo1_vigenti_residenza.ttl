idpt:cubo-pensioni-vigenti-residenza a qb:DataSet ;
    dcterms:description "Numero pensioni e importi per le 107 province italiane, snapshot al 1.1.2026, per 5 tipi di gestione (privati, pubblici, autonomi/parasub, assistenziali, totale). Aggregazione 8 ex-province sarde INPS → 5 province AGID attuali con somma su conteggi e media pesata sugli importi. Importo annuo in milioni di euro. Fonte: INPS Osservatorio Statistico."@it ;
    dcterms:issued "2026-05-29"^^xsd:date ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:rights "Dati derivati da INPS (licenza IODL 2.0), riconfezionati come Linked Open Data con licenza CC-BY 4.0 (compatibile)."@it ;
    dcterms:source <https://www.inps.it/osservatorio/pensioni-vigenti> ;
    dcterms:title "Pensioni INPS vigenti per provincia di residenza, 1.1.2026"@it ;
    qb:structure idpt:dsd-pensioni-vigenti-residenza .

